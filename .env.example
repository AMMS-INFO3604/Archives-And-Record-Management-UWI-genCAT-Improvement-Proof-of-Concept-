# =============================================================================
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values before running the app.
#
#   cp .env.example .env
#
# .env is listed in .gitignore and will never be committed.
# .env.example SHOULD be committed – it documents what variables are needed.
# =============================================================================


# =============================================================================
# Flask
# =============================================================================

FLASK_APP=wsgi.py
FLASK_DEBUG=True
FLASK_RUN_PORT=8080


# =============================================================================
# Security
# =============================================================================
# Generate a strong secret key for production, e.g.:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=dev-secret-key-change-in-production


# =============================================================================
# Database
# =============================================================================
# Leave commented out to use the default SQLite database (local dev).
# Uncomment and fill in to use PostgreSQL (staging / production).
#
# PostgreSQL format:
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
#
# Examples:
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/gencat_db
#   DATABASE_URL=postgresql://postgres:password@db:5432/gencat_db   # Docker
#
# Cloud platforms (Heroku, Render, Railway) set DATABASE_URL automatically.
# The app normalises legacy "postgres://" URIs to "postgresql://" for you.

# DATABASE_URL=postgresql://postgres:password@localhost:5432/gencat_db


# =============================================================================
# JWT
# =============================================================================
# Uncomment to override JWT defaults set in App/config.py

# JWT_SECRET_KEY=another-secret-key-for-jwt
# JWT_ACCESS_TOKEN_EXPIRES=3600
